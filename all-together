<!DOCTYPE html>
<html>
<head>
<title>🐾 PawFacts - Cat Facts</title>

<style>
body {
  background: #ffd6e7;
  font-family: "Comic Sans MS", cursive;
  text-align: center;
  color: #7a3b5c;
  margin: 0;
  padding: 30px;
}

/* 🌸 Decorations */
.decor {
  font-size: 30px;
  letter-spacing: 8px;
}

/* 🐱 Main card */
.card {
  background: white;
  max-width: 500px;
  margin: 30px auto;
  padding: 30px;
  border-radius: 35px;
  box-shadow: 0 0 25px #ffb6d9;
  border: 5px solid #ffc1dd;
}

/* 🎀 Title */
h1 {
  color: #ff69b4;
  text-shadow: 2px 2px #ffd1e6;
}

/* 😽 Cat face */
.cat {
  font-size: 70px;
}

/* 🐾 Fact */
.fact {
  background: #fff0f7;
  padding: 20px;
  border-radius: 25px;
  font-size: 20px;
}

/* 💗 Button */
button {
  margin-top: 20px;
  background: #ffb6d9;
  border: none;
  border-radius: 25px;
  padding: 15px 25px;
  font-size: 18px;
  cursor: pointer;
  color: white;
}

button:hover {
  background: #ff8fc7;
}

/* 📚 Learning note */
.note {
  margin-top: 20px;
  font-size: 14px;
  color: #a45b7b;
}
</style>

</head>

<body>

<div class="decor">
🐾 ✨ 💕 🌸 ✨ 🐾
</div>

<div class="card">

<div class="cat">
😽
</div>

<h1>🐱 PawFacts 🐱</h1>

<p>
A cute cat facts project!
</p>

<div class="fact" id="fact">
🐾 Slow blinks can be a way cats show trust and comfort!
</div>

<button onclick="nextFact()">
🐾 Next Fact 🐾
</button>

<div class="note">
💗 Beginner coding project made for learning and practice!<br>
🌸 Still growing and adding new features!
</div>

</div>

<div class="decor">
🍓 ☁️ 🌸 🐾 💕
</div>


<script>

let facts = [
"🐾 Slow blinks can be a way cats show trust and comfort!",
"🐱 A cat showing their belly can mean they feel safe!",
"✨ Cats use whiskers to help sense their surroundings!",
"😺 Cats have their own unique personalities!",
"🐾 Cats often knead with their paws when they feel comfortable!"
];

let number = 0;

function nextFact() {
  number++;

  if (number >= facts.length) {
    number = 0;
  }

  document.getElementById("fact").innerHTML = facts[number];
}

</script>

</body>
</html>